# Thalassa Marine Weather — Environment Variables
# Copy this file to .env and fill in your values

# ── Required ──
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=sb_publishable_your-project-key
VITE_MAPBOX_ACCESS_TOKEN=your-mapbox-access-token

# ── Optional client-visible services ──
VITE_OWM_API_KEY=your-openweathermap-api-key

# Paid provider credentials (Rainbow, Open-Meteo, Spoonacular, WeatherKit,
# voice/AI services, Stripe, etc.) are Supabase/worker secrets. Never prefix
# those values with VITE_: Vite embeds every VITE_ value in the app bundle.

# ── Optional (monitoring) ──
VITE_SENTRY_DSN=your-sentry-dsn

# ── Auto-set by CI ──
VITE_APP_VERSION=dev

# Calypso Gmail integration — Google OAuth iOS Client ID
# Get it from Google Cloud Console > APIs & Services > Credentials
VITE_GOOGLE_OAUTH_CLIENT_ID=
