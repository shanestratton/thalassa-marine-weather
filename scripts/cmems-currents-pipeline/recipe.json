{
    "version": 1,
    "type": "rasterarray",
    "minzoom": 0,
    "maxzoom": 6,
    "layers": {
        "currents": {
            "tilesize": 512,
            "buffer": 1,
            "resampling": "bilinear",
            "input_no_data_value": -9999,
            "source_rules": {
                "filter": [
                    ["all", ["==", ["get", "NETCDF_DIM_component"], "0"]],
                    ["all", ["==", ["get", "NETCDF_DIM_component"], "1"]]
                ],
                "name": ["case", ["==", ["get", "NETCDF_DIM_component"], "0"], "u", "v"]
            }
        }
    }
}
