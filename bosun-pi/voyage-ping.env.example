# voyage-ping.env — config for the hourly Voyage Log telemetry ping.
#
# Install to /mnt/nvme/bosun/voyage-ping.env (the systemd unit reads it
# via EnvironmentFile). Keep it 600 / owned by skipper — it holds the
# service-role key.

# Supabase project URL.
SUPABASE_URL=https://pcisdplnodrphauixcau.supabase.co

# Service-role key (Supabase Dashboard → Project Settings → API →
# service_role). It bypasses RLS so the Pi can write ship_log rows for
# the owner without interactive auth. Treat it like a password.
SUPABASE_SERVICE_ROLE_KEY=

# The owner's auth.users id — every ship_log row is attributed to this
# user. Find it in Supabase Dashboard → Authentication → Users, or run
#   SELECT auth.uid();
# in the SQL editor while logged in as yourself.
BOSUN_USER_ID=

# SignalK base URL — optional, defaults to http://127.0.0.1:3000
SIGNALK_URL=http://127.0.0.1:3000
