# ═══════════════════════════════════════════════
# Thalassa Pi Cache — Configuration
# ═══════════════════════════════════════════════
# Copy to .env and fill in your values.

# Port for the cache server (default: 3001)
# Signal K uses 3000, AvNav uses 8080 — don't conflict.
PORT=3001

# ── Supabase (forwards requests to your Edge Functions) ──
# Get these from your Thalassa Supabase project dashboard.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...

# ── Cache Settings ──
# Directory for cached data (default: ./cache)
CACHE_DIR=./cache

# How often to pre-fetch weather data (minutes, default: 15)
PREFETCH_INTERVAL=15

# ── Pre-fetch Location (lat,lon for scheduled weather downloads) ──
# Set this to your boat's typical location or cruising ground.
# The Pi will pre-fetch weather for this area on schedule.
PREFETCH_LAT=-36.84
PREFETCH_LON=174.76

# Pre-fetch radius in degrees (covers this area around the point)
PREFETCH_RADIUS=5
